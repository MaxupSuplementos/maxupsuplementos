function setupCompleto() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const ui = SpreadsheetApp.getUi();
  
  Logger.log('Iniciando setup completo MAXUP...');
  
  _setupSuplementos(ss);
  _setupIndumentaria(ss);
  _setupVentasDiarias(ss);
  _setupClientes(ss);
  _setupReposicion(ss);
  _setupBase(ss);
  _setupStockDetallado(ss);
  _setupAnalisisOfertas(ss);
  
  ui.alert('✅ Setup completo.\n\nTodas las hojas migradas desde Excel.\nYa podés usar el menú 🛒 MAXUP.');
}

